/// service-app
model WorkOrder {
  /// 工单ID
  id                    Int      @id @default(autoincrement())
  /// 工单类型名称
  typeName              String
  /// 工单类型
  type                  Int
  /// 流水号
  serial                String   @unique
  /// 服务报告文档URL
  attachment            String
  /// 创建时间
  createdAt             DateTime @default(now())
  /// 更新时间
  updatedAt             DateTime @updatedAt
  /// 备注
  remark                String   @default("")
  /// service-app ID
  serviceAppId          String
  /// 业务类型
  businessType          String   @default("")
  /// 故障详情
  faultDetail           String   @default("")
  /// 工厂id
  factoryId             Int
  /// 故障类别
  faultCategory         String
  /// 原因分析
  possibleCauseAnalysis String
  /// 建议措施
  recommendation        String
  /// 处理措施
  remedialActions       String
  /// 任务详述
  taskDescription       String
  factory               Factory  @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  valve                 Valve[]  @relation("ValveToWorkOrder")

  @@schema("public")
}

/// ServiceApp 推送同步日志: 每次推送的原始 payload 快照, 成功/失败都留档
model ServiceAppPushLog {
  id           Int      @id @default(autoincrement())
  /// 推送方工单 ID (payload.id)
  serviceAppId String?
  /// 工单流水号
  serial       String?
  /// 最终用户名称
  endUserName  String?
  /// 原始 payload
  payload      Json
  /// 同步状态: pending / success / failed
  status       String   @default("pending")
  /// 失败原因 (成功为 null)
  errorMessage String?
  /// 收到推送的时间
  receivedAt   DateTime @default(now())

  @@index([serviceAppId])
  @@index([serial])
  @@index([endUserName])
  @@index([receivedAt])
  @@schema("public")
}
